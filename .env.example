# ─────────────────────────────────────────────────────────────────────────────
# Enterprise Backend Boilerplate — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database (MongoDB) ────────────────────────────────────────────────────────
DATABASE_URL="mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority"

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate secure secrets (run in terminal):
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_use_a_long_random_string_at_least_64_chars
JWT_REFRESH_SECRET=change_me_use_a_different_long_random_string_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# For Gmail: use an App Password (Settings > Security > 2FA > App Passwords)
# For SendGrid: host=smtp.sendgrid.net  port=587  user=apikey  pass=<api_key>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="My App <noreply@example.com>"

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Admin seed user (used by prisma/seed.ts only) ─────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@1234
